{
  "name": "py-noisemaker",
  "version": "0.7.0",
  "description": "Procedural noise generation and creative coding effects",
  "author": "Noise Factor LLC <team@noisefactor.io>",
  "license": "MIT",
  "type": "module",
  "bin": {
    "noisemaker": "./js/bin/noisemaker-js",
    "noisemaker-js": "./js/bin/noisemaker-js"
  },
  "scripts": {
    "dev": "http-server -p 8001",
    "test": "node scripts/run-js-tests.js",
    "test:non-parity": "node scripts/run-js-tests.js --skip-parity",
    "build": "node scripts/build.js",
    "build:cli": "node scripts/build-cli.js",
    "build:standalone": "npm run build:cli && node scripts/build-standalone-cli.js",
    "bundle": "node scripts/bundle.js",
    "bundle:shaders": "node scripts/bundle-shaders.js",
    "bundle:site": "node scripts/bundle-site.js",
    "regress": "node scripts/regress.js",
    "test:shaders": "npm run test:shaders:lang && npm run test:shaders:render && npm run test:shaders:structure",
    "test:shaders:lang": "node shaders/tests/test-unparser.mjs && node shaders/tests/test_parser.js",
    "test:shaders:render": "npm run test:shaders:render:webgl2 && npm run test:shaders:render:webgpu",
    "test:shaders:render:webgl2": "node shaders/mcp/test-harness.js --effects synth/noise --backend webgl2",
    "test:shaders:render:webgpu": "node shaders/mcp/test-harness.js --effects synth/noise --backend webgpu",
    "test:shaders:structure": "node shaders/mcp/test-harness.js --structure-only --backend webgl2",
    "image-regress": "python scripts/image_regression.py",
    "mcp:start": "node shaders/mcp/server.js",
    "mcp:test": "node shaders/mcp/test-harness.js",
    "lint": "eslint js/ scripts/ test/ shaders/ demo/"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.57.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "http-server": "^14.1.1",
    "jpeg-js": "^0.4.4",
    "jsdom": "^27.3.0",
    "pngjs": "^7.0.0",
    "postject": "^1.0.0-alpha.6",
    "puppeteer": "^22.15.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0"
  }
}
